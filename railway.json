{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build --workspace @digital-power/shared && npm run build --workspace @digital-power/backend",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "cmds": [
            "npm ci --workspace @digital-power/shared --workspace @digital-power/backend"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npm run start --workspace @digital-power/backend",
    "preDeployCommand": "npm run db:deploy --workspace @digital-power/backend",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
