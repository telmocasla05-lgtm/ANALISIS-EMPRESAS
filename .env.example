# Copiar a backend/.env y rellenar (Prisma y la API leen backend/.env).

# ── Backend ──────────────────────────────────────────────────────────
# Puerto de la API
PORT=3001

# Cadena de conexión PostgreSQL
DATABASE_URL=postgresql://usuario:password@localhost:5432/digital_power

# Secreto para firmar tokens de sesión (usar un valor largo y aleatorio)
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# ── Informes (API de Claude) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Producción (Railway) ─────────────────────────────────────────────
# Orígenes permitidos para CORS, separados por comas: los dominios de
# Vercel del panel admin y de la web de tablet. Sin definir se acepta
# cualquier origen (solo aceptable en desarrollo local).
# CORS_ORIGINS=https://dp-admin.vercel.app,https://dp-tablet.vercel.app
